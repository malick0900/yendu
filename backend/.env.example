# --- MongoDB ---
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=teranga_stay

# --- App ---
JWT_SECRET=change-me-to-a-long-random-string
APP_NAME=teranga-stay
# Comma-separated list, or "*" (echoes origin) for dev only
CORS_ORIGINS=https://your-frontend.vercel.app

# --- Google OAuth (Google Identity Services) ---
# OAuth 2.0 Client ID from https://console.cloud.google.com/apis/credentials
# Type: "Web application". Same value goes in frontend REACT_APP_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=

# --- Cloudflare R2 (image uploads) ---
# Account ID from Cloudflare dashboard. Create R2 bucket + API token (Object Read & Write).
R2_ACCOUNT_ID=
R2_BUCKET=teranga-stay
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional: override endpoint (defaults to https://<account>.r2.cloudflarestorage.com)
# R2_ENDPOINT=
